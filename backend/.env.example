# =========================================
# Backend Environment Variables
# =========================================

# Server
PORT=5000
NODE_ENV=development

# Database - Supabase PostgreSQL
# Get connection string from: Supabase Dashboard → Settings → Database → Connection String
# Replace [PASSWORD] with your Supabase database password
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.jsucvnqdjbkydkgwmdrc.supabase.co:5432/postgres

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_chars
JWT_EXPIRE=7d

# Security
BCRYPT_ROUNDS=10

# CORS - For production, set this to your Vercel frontend URL
# Example: https://your-project.vercel.app
FRONTEND_URL=http://localhost:8080
